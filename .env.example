# PharmaBula Vercel - Environment Variables
# Copy this file to .env and fill in your values

GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Atlas (free tier: mongodb.com/cloud/atlas)
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/pharmabula?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_atlas_uri_here
