# PharmaBula Vercel - Environment Variables
# Copy this file to .env and fill in your values

# HuggingFace token (free: huggingface.co/settings/tokens)
HF_TOKEN=your_huggingface_token_here

# MongoDB Atlas Data API (optional - for chat session persistence)
# Enable at: Atlas → Data API → Enable → Create API Key
MONGODB_DATA_API_KEY=your_data_api_key_here
MONGODB_DATA_APP_ID=your_app_id_here
