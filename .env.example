# FarmaIA - Simplified Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# MongoDB Connection (REQUIRED)
# ============================================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0

# ============================================================
# LLM Configuration - PRIMARY (REQUIRED)
# ============================================================
# Use ONE provider for primary model
# Recommended models (in order):
#   1. Qwen/Qwen2.5-72B-Instruct (best quality, free on HF)
#   2. meta-llama/Llama-3.3-70B-Instruct (excellent, may require HF Pro)
#   3. meta-llama/Llama-3.1-8B-Instruct:cerebras (fast, but may hallucinate)
PRIMARY_PROVIDER=huggingface
PRIMARY_MODEL=Qwen/Qwen2.5-72B-Instruct
PRIMARY_API_KEY=hf_your_token_here

# ============================================================
# LLM Configuration - FALLBACK (OPTIONAL)
# ============================================================
# Use a different provider or model as fallback
FALLBACK_PROVIDER=huggingface
FALLBACK_MODEL=Qwen/Qwen2.5-72B-Instruct
FALLBACK_API_KEY=hf_your_token_here

# ============================================================
# Notes:
# - Judges use the same PRIMARY/FALLBACK config (no separate keys needed)
# - Keep it simple: 1 primary + 1 fallback is enough
# - All LLM features (planner, response, judges) use these same keys
