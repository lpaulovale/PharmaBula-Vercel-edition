# PharmaBula Vercel - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# LLM Model Configuration
# ============================================================
# Provider options: huggingface, openai, anthropic, google
# Models can be overridden per-request by passing { model: "..." } in the request body

# Primary LLM (used for chat responses and planning)
PRIMARY_PROVIDER=huggingface
PRIMARY_MODEL=meta-llama/Llama-3.1-8B-Instruct:cerebras
PRIMARY_API_KEY=your_huggingface_token_here

# Fallback LLM (optional - used if primary fails)
FALLBACK_PROVIDER=huggingface
FALLBACK_MODEL=meta-llama/Llama-3.1-8B-Instruct:cerebras
FALLBACK_API_KEY=your_huggingface_token_here

# Judge Evaluation Model (can be same or different from primary)
JUDGE_PROVIDER=huggingface
JUDGE_MODEL=meta-llama/Llama-3.1-8B-Instruct:cerebras
JUDGE_API_KEY=your_huggingface_token_here

# Optional: Dedicated Planner Model (recommended: Claude/GPT for better reasoning)
# If not set, uses PRIMARY_MODEL
# PLANNER_PROVIDER=anthropic
# PLANNER_MODEL=claude-sonnet-4-20250514
# PLANNER_API_KEY=your_anthropic_key_here

# ============================================================
# Provider-Specific API Keys (for backward compatibility)
# ============================================================
# These are used if PRIMARY_API_KEY is not set but provider matches

# HuggingFace token (free: huggingface.co/settings/tokens)
HF_TOKEN=your_huggingface_token_here

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_key_here

# Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Google AI API key (https://makersuite.google.com/app/apikey)
GOOGLE_API_KEY=your_google_key_here

# ============================================================
# MongoDB Atlas (free tier: mongodb.com/cloud/atlas)
# ============================================================
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/pharmabula?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_uri_here

# ============================================================
# Webshare Proxy (for ANVISA scraping)
# ============================================================
# Sign up at webshare.io for residential proxies
# This helps bypass ANVISA's anti-bot protection

# Option 1: Full proxy URL (recommended)
# Format: http://username:password@proxy.webshare.io:port
WEBSHARE_PROXY_URL=http://your-username:your-password@proxy.webshare.io:10000

# Option 2: Separate credentials (if not using URL format)
WEBSHARE_USERNAME=your-webshare-username
WEBSHARE_PASSWORD=your-webshare-password

# Server Configuration (Fly.io)
PORT=8080
NODE_ENV=production
